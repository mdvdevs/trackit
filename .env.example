# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js (required in production). Also accepted: NEXTAUTH_SECRET, BETTER_AUTH_SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Next.js Server Actions — use ONE stable key on Vercel (Build + Runtime) or each deploy
# gets a new encryption salt and clients on an old tab see "Server Action was not found".
# Generate: openssl rand -base64 32
# Omit locally unless debugging prod parity; on Vercel set for Build + Runtime.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Google Gemini (for AI parsing)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
